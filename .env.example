# Copy this file to ".env" and fill in your keys.
# ".env" is git-ignored and must NEVER be committed.
#
# You only need keys for the providers you actually want to benchmark.
# A missing key makes the harness skip that provider (it does not crash).

# OpenAI -- GPT models (e.g. GPT-5 mini)
OPENAI_API_KEY=

# Anthropic -- Claude (e.g. Claude Haiku 4.5)
ANTHROPIC_API_KEY=

# Google -- Gemini (e.g. Gemini Flash). Has a free tier.
GOOGLE_API_KEY=

# DeepSeek -- price-leader, called via the OpenAI-compatible endpoint
DEEPSEEK_API_KEY=

# Groq -- fast open-weight models, called via the OpenAI-compatible endpoint
GROQ_API_KEY=
